# Nos OS local environment

# AI provider
# Default is OpenAI. Use "local" to force mock replies or "anthropic" to use Claude.
AI_PROVIDER=openai

# OpenAI
# Keep these server-side only. Never expose them with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=520
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=

# Claude / Anthropic fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Supabase
NOS_OS_DATA_MODE=mock
NEXT_PUBLIC_TEST_BUILD_LABEL=employee-preview
NEXT_PUBLIC_GITHUB_BRANCH_URL=https://github.com/nextonestepinfo-ops/naughty_site_system_project/tree/codex/nos-os-daily-cockpit/nos-os
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEETS_ATTENDANCE_SPREADSHEET_ID=
