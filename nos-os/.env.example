# Nos OS local environment

# AI provider
# Default is OpenAI. Use "local" to force mock replies or "anthropic" to use Claude.
AI_PROVIDER=openai

# OpenAI
# Keep these server-side only. Never expose them with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=520
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
OPENAI_TASK_PLANNER_MODEL=
OPENAI_TASK_PLANNER_MAX_OUTPUT_TOKENS=1400
OPENAI_TASK_PLANNER_REASONING_EFFORT=low
OPENAI_TASK_PLANNER_TEXT_VERBOSITY=low
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=

# Claude / Anthropic fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Supabase
NOS_OS_DATA_MODE=supabase
NEXT_PUBLIC_TEST_BUILD_LABEL=employee-preview
NEXT_PUBLIC_GITHUB_BRANCH_URL=https://github.com/nextonestepinfo-ops/naughty_site_system_project/tree/codex/nos-os-daily-cockpit/nos-os
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push / PWA background notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nos-tech.com
NOS_OS_CRON_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEETS_ATTENDANCE_SPREADSHEET_ID=
