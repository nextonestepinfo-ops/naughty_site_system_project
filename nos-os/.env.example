# Nos OS local environment

# Claude / Anthropic
# Keep this server-side only. Never expose it with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# Put the Claude model ID you choose from Anthropic Console/docs.
# Nos OS intentionally does not hardcode a changing model name.
ANTHROPIC_MODEL=

# Future integrations
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEETS_ATTENDANCE_SPREADSHEET_ID=

